<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:padding="16dp">

    <!-- ОСНОВНОЙ КОНТЕЙНЕР ДЛЯ ИГРЫ (Сгруппирован, чтобы не перекрываться стартовым экраном) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Верхняя панель: Статистика -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:weightSum="3">

            <TextView android:id="@+id/tvLevel"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Уровень: 1" android:textStyle="bold" android:textColor="#333333" android:textSize="16sp"/>

            <TextView android:id="@+id/tvRadix"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="СС: 10" android:gravity="start" android:textStyle="bold" android:textColor="#00574B" android:textSize="16sp"/>

            <TextView android:id="@+id/tvLives"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Жизни: ❤️❤️❤️" android:gravity="end" android:textColor="#D32F2F" android:textSize="16sp"/>
        </LinearLayout>

        <!-- Индикатор времени (Таймер) -->
        <ProgressBar
            android:id="@+id/progressBarTimer"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="12dp"
            android:progressTint="#FF9800"/>

        <!-- Карточка с главным заданием -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuestion"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvQuestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 + 6 &lt; 10?"
                    android:textColor="#212121"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Блок ввода обычного ответа (Число) -->
        <LinearLayout
            android:id="@+id/layoutInputAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="vertical"
            android:visibility="visible">

            <EditText
                android:id="@+id/etAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите ответ в текущей СС"
                android:inputType="text"
                android:padding="14dp"
                android:textSize="18sp"/>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Проверить"
                android:backgroundTint="#008577"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Блок ввода логического ответа (Да / Нет) -->
        <LinearLayout
            android:id="@+id/layoutBinaryAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:visibility="gone">

            <Button
                android:id="@+id/btnYes"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="ДА"
                android:backgroundTint="#4CAF50"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnNo"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="НЕТ"
                android:backgroundTint="#F44336"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- СТАРТОВЫЙ ЭКРАН (Обязательно идет последним элементом внутри RelativeLayout, чтобы быть НАД игрой) -->
    <LinearLayout
        android:id="@+id/layoutStartScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7FA"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Тренируем счет 2.0"
            android:textColor="#333333"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnGameStart"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="НАЧАТЬ"
            android:backgroundTint="#008577"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>
